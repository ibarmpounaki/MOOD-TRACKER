<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.2/css/all.css"
    />
    <link rel="stylesheet" href="/styles/signup.css" />
    <title>Daily Tracker</title>
  </head>

  <body>
    <div class="signup-wrap">
      <!-- LEFT -->
      <div class="left-panel">
        <div class="brand">
          <div class="brand-name">Daily Tracker<br /></div>

          <p class="brand-sub">
            Start your journaling habit today.<br />It only takes a minute.
          </p>

          <div class="steps">
            <div class="step">
              <div class="step-num">1</div>
              <div class="step-text">
                <strong>Create your account</strong>
                <span>Pick a username and password</span>
              </div>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <div class="step-text">
                <strong>Write your first entry</strong>
                <span>Morning, afternoon or evening</span>
              </div>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <div class="step-text">
                <strong>Build your streak</strong>
                <span>Track moods, habits and your year</span>
              </div>
            </div>
          </div>
        </div>

        <div class="left-bottom">
          <p class="already">
            Already have an account? <a href="/login">Sign in</a>
          </p>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="right-panel">
        <p class="login-title">Get started</p>
        <h1 class="login-heading">Create your<br /><em>account</em></h1>

        <form method="POST" action="/signup">
          <div class="form-row-2">
            <div class="form-group no-mb">
              <label class="form-label">First Name</label>
              <input
                class="form-input"
                type="text"
                name="firstName"
                placeholder="Charlie…"
              />
            </div>
            <div class="form-group no-mb">
              <label class="form-label">Last Name</label>
              <input
                class="form-input"
                type="text"
                name="lastName"
                placeholder="Smith…"
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Username</label>
            <input
              class="form-input"
              type="text"
              name="username"
              placeholder="Your unique name…"
              autocomplete="username"
            />
          </div>

          <div class="form-group">
            <label class="form-label">Password</label>
            <input
              class="form-input"
              type="password"
              name="password"
              id="passwordInput"
              placeholder="••••••••"
              autocomplete="new-password"
            />
            <div class="strength-bar">
              <div class="strength-seg" id="seg1"></div>
              <div class="strength-seg" id="seg2"></div>
              <div class="strength-seg" id="seg3"></div>
              <div class="strength-seg" id="seg4"></div>
            </div>
            <div class="strength-label" id="strengthLabel"></div>
          </div>

          <div class="form-group">
            <label class="form-label">Confirm Password</label>
            <input
              class="form-input"
              type="password"
              name="confirmPassword"
              id="confirmInput"
              placeholder="••••••••"
              autocomplete="new-password"
            />
          </div>

          <button type="submit" class="signup-btn">Create Account</button>
        </form>
      </div>
    </div>

    <a href="/login">Go Back</a>
  </body>
</html>
