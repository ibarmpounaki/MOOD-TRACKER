<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.2/css/all.css"
    />
    <!-- <link rel="stylesheet" href="/styles/signup.css" /> -->
    <link rel="stylesheet" href="/styles/auth.css" />

    <title>Daily Tracker</title>
  </head>

  <body>
    <div class="signup-wrap">
      <!-- LEFT -->
      <div class="left-panel">
        <div class="brand">
          <div class="brand-name">Daily Tracker<br /></div>

          <p class="brand-sub">
            Start your journaling habit today.<br />It only takes a minute.
          </p>

          <div class="steps">
            <div class="step">
              <div class="step-num">1</div>
              <div class="step-text">
                <strong>Create your account</strong>
                <span>Pick a username and password</span>
              </div>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <div class="step-text">
                <strong>Write your first entry</strong>
                <span>Morning, afternoon or evening</span>
              </div>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <div class="step-text">
                <strong>Build your streak</strong>
                <span>Track moods, habits and your year</span>
              </div>
            </div>
          </div>
        </div>

        <div class="left-bottom">
          <p class="already">
            Already have an account? <a href="/login">Sign in</a>
          </p>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="right-panel">
        <div class="form-wrapper">
          <!-- Titles -->
          <div class="login-titles">
            <h4>GET STARTED</h4>
            <h1>
              Create your
              <span class="accountTxt">account</span>
            </h1>
          </div>

          <!-- Form -->
          <div class="login-form-container">
            <form method="POST" action="/signup" class="login-fillin-boxes">
              <div class="form-row-2">
                <div class="form-group">
                  <label class="form-label">First Name *</label>
                  <input
                    class="form-input"
                    type="text"
                    name="name"
                    placeholder="Charlie…"
                    required
                  />
                </div>

                <div class="form-group">
                  <label class="form-label">Last Name *</label>
                  <input
                    class="form-input"
                    type="text"
                    name="lastName"
                    placeholder="Smith…"
                    required
                  />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Email *</label>
                <input
                  class="form-input"
                  type="text"
                  name="email"
                  placeholder="Your email…"
                  required
                />
              </div>

              <div class="form-group">
                <label class="form-label">Password *</label>
                <input
                  class="form-input"
                  type="password"
                  name="password"
                  id="passwordInput"
                  placeholder="••••••••"
                  required
                />

                <div class="strength-bar">
                  <div class="strength-seg" id="seg1"></div>
                  <div class="strength-seg" id="seg2"></div>
                  <div class="strength-seg" id="seg3"></div>
                  <div class="strength-seg" id="seg4"></div>
                </div>

                <div class="strength-label" id="strengthLabel"></div>
              </div>

              <div class="form-group">
                <label class="form-label">Confirm Password *</label>
                <input
                  class="form-input"
                  type="password"
                  name="confirmPassword"
                  id="confirmInput"
                  placeholder="••••••••"
                  required
                />
              </div>
              <p id="passwordMessage" class="password-message"></p>
              <button type="submit" class="login-btn">Create Account</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- <a href="/login">Go Back</a> -->
  </body>
  <script src="/js/signup.js"></script>
</html>
