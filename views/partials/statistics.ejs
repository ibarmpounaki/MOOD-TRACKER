  <div class="stats-topbar">
    <h2 class="stats-title">Your statistics</h2>
    <div class="stats-filters">
      <% [7, 30].forEach(d => { %>
        <span class="stats-pill <%= days === d ? 'active' : '' %>" data-days="<%= d %>">
          <%= d + ' days' %>
        </span>
      <% }) %>
    </div>
  </div>

  <!-- cards -->
  <div class="stats-metrics">
    <div class="stats-metric">
      <div class="stats-metric-label">Current streak</div>
      <div class="stats-metric-value streak-value"><%= streak %></div>
      <div class="stats-metric-sub">days in a row</div>
    </div>
    <div class="stats-metric">
      <div class="stats-metric-label">Days logged</div>
      <div class="stats-metric-value daysLogged-value"><%= daysLogged %></div>
      <div class="stats-metric-sub">in the last <%= days %> days</div>
    </div>
    <div class="stats-metric">
      <div class="stats-metric-label">Average mood</div>
      <div class="stats-metric-value avgMood-value"><%= averageMood %></div>
      <div class="stats-metric-sub">across all periods</div>
    </div>
    <div class="stats-metric">
      <div class="stats-metric-label">Best day</div>
      <div class="stats-metric-value bestDay-value"><%= bestDay %></div>
      <div class="stats-metric-sub">highest mood across all periods</div>
    </div>
  </div>

  <!-- mood over time - chart -->
  <div class="stats-card">
    <div class="stats-card-title">Mood over time</div>
    <div style="position:relative;width:100%;height:200px">
      <canvas id="moodChart" role="img"
        aria-label="Line chart showing morning, afternoon and evening mood over the selected period">
        Mood trend over selected period.
      </canvas>
    </div>
    <div class="chart-legend">
      <span><span class="legend-dot" style="background:#534AB7"></span>Morning</span>
      <span><span class="legend-dot" style="background:#1D9E75"></span>Afternoon</span>
      <span><span class="legend-dot" style="background:#EF9F27"></span>Evening</span>
    </div>
  </div>

  <% if (consistentMood) { %>
    <div class="chart-notice">
      Your mood was consistent across all periods of the day.
    </div>
  <% } %>
  
  <div class="stats-row-2">
    <!-- mood breakdown -->
    <div class="stats-card">
      <div class="stats-card-title">Mood breakdown</div>
      <% moodBreakdown.forEach(m => { %>
        <div class="mood-bar-row">
          <span class="mood-bar-label"><%= m.name %></span>
          <div class="mood-bar-track">
            <div class="mood-bar-fill" style="width:<%= m.pct %>%;background:<%= 
              {excellent:'#3db878',great:'#4a9e80',good:'#6080c8',okay:'#92a8e0',bad:'#c8d4f0'}[m.name] %>">
            </div>
          </div>
          <span class="mood-bar-pct"><%= m.pct %>%</span>
        </div>
      <% }) %>
    </div>

    <!-- By time of day -->
    <div class="stats-card">
      <div class="stats-card-title">By time of day</div>
      <% periodStats.forEach(p => { %>
        <div class="period-stat-row">
          <span class="period-stat-label"><%= p.period.charAt(0).toUpperCase() + p.period.slice(1) %></span>
          <span class="period-stat-avg"><%= p.avgName %></span>
          <span class="period-stat-entries"><%= p.entries %> entries</span>
        </div>
      <% }) %>
    </div>
  </div>

  <%
    const statsTagIcons = {
        'Exercised':       'ti-run',
        'Ate Healthy':     'ti-apple',
        'Meditated':       'ti-heart',
        'Slept Well':      'ti-moon',
        'Productive':      'ti-check',
        'Deep Work':       'ti-target',
        'Walked':          'ti-walk',
        'No Screens':      'ti-device-mobile-off',
        'Read':            'ti-book',
    };
  %>

  <!--Top tags -->
  <div class="stats-card">
    <div class="stats-card-title">Top tags</div>
    <div class="tag-cloud">
      <% topTags.forEach((t, i) => { %>
        <span class="tag-item <%= i < 2 ? 'tag-lg' : 'tag-md' %>">  <!-- top 3 -->
          <i class="ti <%= statsTagIcons[t.tag] || 'ti-tag' %>" aria-hidden="true"></i>
          <%= t.tag.toUpperCase() %> <span class="tag-count"><%= t.count %></span>
        </span>
      <% }) %>
    </div>
  </div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<script>
  const labels     = <%- chartLabels %>;
  const morning    = <%- chartMorning %>;
  const afternoon  = <%- chartAfternoon %>;
  const evening    = <%- chartEvening %>;
  const moodNames  = ['','Bad','Okay','Good','Great','Excellent'];

  const moodChart = new Chart(document.getElementById('moodChart'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label:'Morning',   data:morning,   borderColor:'#d4831a', backgroundColor:'transparent', pointBackgroundColor: '#d4831a', tension:.4, pointRadius:2, borderWidth:1.8, fill:true,  spanGaps:true },
        { label:'Afternoon', data:afternoon, borderColor:'#5b77c4', backgroundColor:'transparent', pointBackgroundColor: '#5b77c4', tension:.4, pointRadius:2, borderWidth:1.8, fill:false, spanGaps:true },
        { label:'Evening',   data:evening,   borderColor:'#7b5ea8', backgroundColor:'transparent', pointBackgroundColor: '#7b5ea8', tension:.4, pointRadius:2, borderWidth:1.8, fill:false, spanGaps:true },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { 
            usePointStyle: true, // changes box to a circle matching the line dot
            boxWidth: 5,
            boxHeight: 5,
            callbacks: {
              title: ctx => {
                const date = new Date(labels[ctx[0].dataIndex]);
                return date.toLocaleDateString("en-GB", { day: "2-digit", month: "long", year: "numeric" });
              },
              label: ctx => `${ctx.dataset.label}: ${moodNames[ctx.raw] || ''}`
          }
        }
      },
      scales: {
        y: { min:0.5, max:5.6, ticks:{ stepSize:1, callback: v => moodNames[v]||'', font:{size:10} }, grid:{ color:'rgba(128,128,128,.08)' }},
        x: { 
          ticks: { 
            maxTicksLimit:10, 
            font:{size:10},
            callback: function(value, index) {
              const date = new Date(labels[index]);
              return date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
            }
          }, 
          grid:{ display:false }
        }
      }
    }
  });
</script>

