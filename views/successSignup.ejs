<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.2/css/all.css"
    />
    <link rel="stylesheet" href="/styles/successSignup.css" />

    <title>Daily Tracker</title>
  </head>
  <body>
    <div class="success-card">
      <!-- animated checkmark -->
      <div class="successContent">
        <div class="check-wrap">
          <svg class="check-icon" viewBox="0 0 24 24">
            <path class="check-path" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <p class="success-Title">Account created</p>
        <h1 class="success-heading">You're all set!</h1>
        <p class="success-sub">
          Your journal is ready. Start writing about your day; morning,
          afternoon or evening.
        </p>
      </div>

      <a href="/login" class="login-btn">Go to Login</a>
    </div>
    <script src="/js/successSignup.js"></script>
  </body>
</html>
